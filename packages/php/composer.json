{
  "name": "manishapay/manishapay",
  "description": "Official PHP SDK for ManishaPay — PayNow Zimbabwe middleware",
  "type": "library",
  "license": "MIT",
  "keywords": ["paynow", "zimbabwe", "ecocash", "payments", "manishapay"],
  "authors": [
    { "name": "Noby Tebulo", "homepage": "https://noby.aizim.co.zw" }
  ],
  "require": {
    "php": ">=7.4",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6 || ^10.5"
  },
  "autoload": {
    "psr-4": {
      "ManishaPay\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ManishaPay\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "support": {
    "issues": "https://github.com/nobytechy/manishapay-sdks/issues",
    "source": "https://github.com/nobytechy/manishapay-sdks/tree/main/packages/php"
  },
  "homepage": "https://pay.aizim.co.zw"
}
